<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Game Gallery</title>
    <style>
        .container {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-around;
        }

        .game-link {
            display: block;
            text-align: center;
            width: 31%; /* Approximately one third of the container, adjusting for margins */
            margin: 1%;
            text-decoration: none;
            color: black; /* Color for the text */
        }

        .game-link img {
            width: 100%;
            aspect-ratio: 16 / 9; /* Keeps the aspect ratio at 16:9 */
            display: block;
        }

        .game-link p {
            margin-top: 8px;
        }

        .game-link:hover {
            outline: 2px solid purple; /* Purple outline on hover */
        }
    </style>
</head>
<body>
    <div class="container">
        <a href="https://mas0ng.com/all games/basketbros.html" class="game-link">
