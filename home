<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Welcome to mas0ng.com</title>
<style>
  body {
    font-family: 'Arial', sans-serif;
    margin: 0;
    padding: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    background: #fff;
  }
  .navbar {
    position: absolute;
    top: 0;
    width: 100%;
    display: flex;
    justify-content: space-between;
    padding: 10px 50px;
  }
  .navbar ul {
    list-style: none;
    display: flex;
    gap: 20px;
  }
  .navbar ul li {
    padding: 5px 10px;
  }
  .navbar ul li a {
    text-decoration: none;
    color: #333;
  }
  .branding {
    text-align: center;
  }
  .branding h1 {
    font-size: 3em;
    background: -webkit-linear-gradient(left, #654ea3, #eaafc8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .explore-btn {
    display: inline-block;
    padding: 10px 20px;
    margin-top: 20px;
    border: 2px solid #654ea3;
    border-radius: 5px;
    background: transparent;
    color: #654ea3;
    text-decoration: none;
    font-weight: bold;
    transition: all 0.3s ease;
  }
  .explore-btn:hover {
    background: #654ea3;
    color: #fff;
  }
  .explore-btn:after {
    content: '→';
    display: inline-block;
    margin-left: 10px;
    transition: margin-left 0.3s ease;
  }
  .explore-btn:hover:after {
    margin-left: 15px;
  }
</style>
</head>
<body>
<div class="navbar">
  <ul>
    <li><a href="#">Servers</a></li>
    <li><a href="#">Users</a></li>
    <li><a href="#">Emojis</a></li>
    <li><a href="#">Bans</a></li>
    <li><a href="#">Buy credits</a></li>
  </ul>
</div>
<div class="branding">
  <h1>Welcome to mas0ng.com</h1>
  <a href="#" class="explore-btn">Explore</a>
</div>
</body>
</html>
